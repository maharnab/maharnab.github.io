---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav class="shell">
		<div class="identity">
			<h1><a href="/">{SITE_TITLE}</a></h1>
			<p>Experimental Physicist | Detector R&amp;D | Scientific Computing</p>
		</div>
		<div class="links">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/about">About</HeaderLink>
			<HeaderLink href="/blog">Blog</HeaderLink>
		</div>
		<div class="externals">
			<a href="https://github.com/maharnab" target="_blank" rel="noreferrer">GitHub</a>
			<a href="https://www.linkedin.com/in/maharnabb" target="_blank" rel="noreferrer">LinkedIn</a>
		</div>
	</nav>
</header>
<style>
	header {
		position: sticky;
		top: 0;
		z-index: 5;
		backdrop-filter: blur(8px);
		background: color-mix(in oklab, var(--surface) 88%, transparent);
		border-bottom: 1px solid var(--line-soft);
	}

	h1 {
		margin: 0;
		font-size: clamp(1.1rem, 2vw, 1.35rem);
		line-height: 1;
	}

	h1 a,
	h1 a.active {
		text-decoration: none;
		color: var(--text-strong);
	}

	.shell {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 0.75rem;
		max-width: 1080px;
		padding: 0.9rem 1rem;
		margin: 0 auto;
	}

	.identity p {
		margin: 0.2rem 0 0;
		font-size: 0.76rem;
		letter-spacing: 0.02em;
		color: var(--text-muted);
	}

	.links {
		display: flex;
		gap: 0.25rem;
	}

	.links a {
		padding: 0.45rem 0.7rem;
		border-radius: 999px;
		color: var(--text-normal);
		border: 1px solid transparent;
		text-decoration: none;
	}

	.links a:hover {
		border-color: var(--line-strong);
		background: color-mix(in oklab, var(--surface-2) 80%, transparent);
	}

	.externals {
		display: flex;
		gap: 0.7rem;
		font-size: 0.88rem;
	}

	.externals a {
		color: var(--text-muted);
		text-decoration: none;
	}

	.externals a:hover {
		color: var(--accent-strong);
	}

	@media (max-width: 840px) {
		.shell {
			flex-wrap: wrap;
		}

		.externals {
			width: 100%;
			justify-content: flex-end;
		}
	}
</style>
