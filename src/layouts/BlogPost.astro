---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { DISQUS_SHORTNAME, GOATCOUNTER_DOMAIN, SITE_TITLE } from '../consts';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, slug } = Astro.props as Props & { slug: string };
const formatISODate = (date: Date) => date.toISOString().slice(0, 10);
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const shareURL = encodeURIComponent(canonicalURL.toString());
const shareText = encodeURIComponent(`${title} | ${SITE_TITLE}`);
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
		<link
			rel="stylesheet"
			href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css"
		/>
		<style>
			main {
				padding-top: 1.2rem;
			}
			.prose {
				max-width: 760px;
				margin: 0 auto;
			}
			.title {
				padding: 1.2rem;
				margin-bottom: 1rem;
				border: 1px solid var(--line-soft);
				border-radius: 14px;
				background: var(--surface);
			}
			.title h1 {
				margin: 0.4rem 0;
			}
			.date {
				margin: 0.25rem 0 0.35rem;
				color: var(--text-muted);
				font-size: 0.92rem;
			}
			.last-updated-on {
				margin-top: 1.1rem;
				padding-top: 0.75rem;
				border-top: 1px dashed var(--line-soft);
				font-style: italic;
				font-size: 0.86rem;
				color: var(--text-muted);
			}
			.post-tools {
				margin-top: 1rem;
				padding-top: 0.8rem;
				border-top: 1px dashed var(--line-soft);
				display: flex;
				flex-wrap: wrap;
				align-items: center;
				justify-content: space-between;
				gap: 0.75rem;
			}
			.share-links {
				display: flex;
				flex-wrap: wrap;
				gap: 0.45rem;
			}
			.share-links a,
			.share-links button {
				border: 1px solid var(--line-soft);
				background: color-mix(in oklab, var(--surface) 92%, white);
				color: var(--text-strong);
				text-decoration: none;
				padding: 0;
				width: 2.2rem;
				height: 2.2rem;
				display: inline-flex;
				align-items: center;
				justify-content: center;
				border-radius: 999px;
				font-size: 0.95rem;
				cursor: pointer;
			}
			.share-links i {
				font-size: 1.1rem;
				line-height: 1;
			}
			.share-links .fa-copy {
				font-size: 1.02rem;
			}
			.share-links a:hover,
			.share-links button:hover {
				border-color: var(--line-strong);
				background: color-mix(in oklab, var(--surface-2) 78%, white);
			}
			.views {
				font-size: 0.86rem;
				color: var(--text-muted);
			}
			.comments {
				margin-top: 1.25rem;
				padding-top: 0.85rem;
				border-top: 1px solid var(--line-soft);
			}
			.comments h2 {
				margin: 0 0 0.8rem;
				font-size: 1.2rem;
			}
			article {
				padding: 1.2rem;
				border: 1px solid var(--line-soft);
				border-radius: 14px;
				background: var(--surface);
			}
			@media (max-width: 720px) {
				article,
				.title {
					padding: 1rem;
				}
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<div class="prose">
					<div class="title">
						<h1>{title}</h1>
						<div class="date">
							Published: {formatISODate(pubDate)}
						</div>
						<p class="meta">{description}</p>
					</div>
					<slot />
					<div class="post-tools">
						<div class="share-links" aria-label="Share this post">
							<a href={`https://twitter.com/intent/tweet?url=${shareURL}&text=${shareText}`} target="_blank" rel="noreferrer" aria-label="Share on X" title="Share on X">
								<i class="fa-brands fa-x-twitter" aria-hidden="true"></i>
							</a>
							<a href={`https://www.linkedin.com/sharing/share-offsite/?url=${shareURL}`} target="_blank" rel="noreferrer" aria-label="Share on LinkedIn" title="Share on LinkedIn">
								<i class="fa-brands fa-linkedin-in" aria-hidden="true"></i>
							</a>
							<a href={`https://www.reddit.com/submit?url=${shareURL}&title=${shareText}`} target="_blank" rel="noreferrer" aria-label="Share on Reddit" title="Share on Reddit">
								<i class="fa-brands fa-reddit-alien" aria-hidden="true"></i>
							</a>
							<a href={`https://www.facebook.com/sharer/sharer.php?u=${shareURL}`} target="_blank" rel="noreferrer" aria-label="Share on Facebook" title="Share on Facebook">
								<i class="fa-brands fa-facebook-f" aria-hidden="true"></i>
							</a>
							<a href={`https://t.me/share/url?url=${shareURL}&text=${shareText}`} target="_blank" rel="noreferrer" aria-label="Share on Telegram" title="Share on Telegram">
								<i class="fa-brands fa-telegram" aria-hidden="true"></i>
							</a>
							<a href={`https://wa.me/?text=${shareText}%20${shareURL}`} target="_blank" rel="noreferrer" aria-label="Share on WhatsApp" title="Share on WhatsApp">
								<i class="fa-brands fa-whatsapp" aria-hidden="true"></i>
							</a>
							<button type="button" id="copy-link" aria-label="Copy post link" title="Copy post link">
								<i class="fa-regular fa-copy" aria-hidden="true"></i>
							</button>
						</div>
						{GOATCOUNTER_DOMAIN && <div class="views">Views: <span id="view-count">-</span></div>}
					</div>
					{updatedDate && <div class="last-updated-on">Last updated: {formatISODate(updatedDate)}</div>}
					{
						DISQUS_SHORTNAME && (
							<section class="comments" aria-label="Comments section">
								<h2>Comments</h2>
								<div id="disqus_thread"></div>
							</section>
						)
					}
				</div>
			</article>
		</main>
		<script is:inline>
			const copyBtn = document.getElementById('copy-link');
			if (copyBtn) {
				copyBtn.addEventListener('click', async () => {
					try {
						await navigator.clipboard.writeText(window.location.href);
						copyBtn.setAttribute('title', 'Copied');
						copyBtn.setAttribute('aria-label', 'Copied');
						setTimeout(() => {
							copyBtn.setAttribute('title', 'Copy post link');
							copyBtn.setAttribute('aria-label', 'Copy post link');
						}, 1200);
					} catch {
						copyBtn.setAttribute('title', 'Copy failed');
						copyBtn.setAttribute('aria-label', 'Copy failed');
					}
				});
			}
		</script>
		{
			GOATCOUNTER_DOMAIN && (
				<>
					<script
						async
						data-goatcounter={`https://${GOATCOUNTER_DOMAIN}.goatcounter.com/count`}
						src="//gc.zgo.at/count.js"
					></script>
					<script is:inline define:vars={{ goatcounterDomain: GOATCOUNTER_DOMAIN }}>
						const vc = document.getElementById('view-count');
						if (vc) {
							const path = encodeURIComponent(window.location.pathname);
							fetch(`https://${goatcounterDomain}.goatcounter.com/counter/${path}.json`)
								.then((r) => r.json())
								.then((data) => {
									if (typeof data.count === 'number') vc.textContent = String(data.count);
								})
								.catch(() => {
									vc.textContent = '-';
								});
						}
					</script>
				</>
			)
		}
		{
			DISQUS_SHORTNAME && (
				<script
					is:inline
					define:vars={{
						disqusShortname: DISQUS_SHORTNAME,
						disqusUrl: canonicalURL.toString(),
						disqusIdentifier: slug,
					}}
				>
					window.disqus_config = function () {
						this.page.url = disqusUrl;
						this.page.identifier = disqusIdentifier;
					};
					const d = document;
					const s = d.createElement('script');
					s.src = `https://${disqusShortname}.disqus.com/embed.js`;
					s.setAttribute('data-timestamp', String(+new Date()));
					(d.head || d.body).appendChild(s);
				</script>
			)
		}
		<Footer />
	</body>
</html>
